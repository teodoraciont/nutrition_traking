datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  cognitoId   String   @unique
  startWeight Float?
  goalWeight  Float?
  gymGoal     Int?
  createdAt   DateTime @default(now())
  entries     GymEntry[]
}

model GymEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  kcal      Int?
  protein   Float?
  weight    Float?
  gym       Boolean  @default(false)
  foodNote  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}
